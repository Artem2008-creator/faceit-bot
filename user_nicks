"""Хранение Faceit-ников пользователей Telegram."""

from __future__ import annotations

import json
from pathlib import Path

NICKS_FILE = "/opt/render/project/data/user_nicks.json"


class UserNickStore:
    """telegram_user_id (str) → faceit nickname."""

    def __init__(self, path: Path = NICKS_FILE) -> None:
        self._path = path
        self._data: dict[str, str] = {}
        self._load()

    def _load(self) -> None:
        if not self._path.exists():
            self._data = {}
            return
        try:
            raw = json.loads(self._path.read_text(encoding="utf-8"))
            if isinstance(raw, dict):
                self._data = {str(k): str(v) for k, v in raw.items()}
        except (json.JSONDecodeError, OSError):
            self._data = {}

    def _save(self) -> None:
        self._path.write_text(
            json.dumps(self._data, ensure_ascii=False, indent=2),
            encoding="utf-8",
        )

    def get(self, telegram_user_id: int) -> str | None:
        return self._data.get(str(telegram_user_id))

    def set(self, telegram_user_id: int, nickname: str) -> None:
        self._data[str(telegram_user_id)] = nickname.strip()
        self._save()
